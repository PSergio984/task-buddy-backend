# Exclude local environment files
.venv/
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.ruff_cache/
.mypy_cache/

# Exclude sensitive information
.env
*.db
*.sqlite3

# Exclude version control
.git/
.gitignore

# Exclude Docker related files
Dockerfile
docker-compose.yml
.dockerignore

# Exclude metadata and logs
.claude/
.gemini/
.vscode/
app.log
*.log
