
APP_NAME=Task_Buddy
DEBUG=True
LOG_LEVEL=INFO
ENV_STATE=DEV
# Controls seed guard — set to "production" on Render to block accidental demo-user data wipe.
# Override with SEED_ALLOWED=true if seeding is intentionally needed on production.
APP_ENV=development

SENTRY_DSN=https://your-public-key@your-org.ingest.sentry.io/your-project-id
DATABASE_URL=postgresql://user:password@localhost:5432/task_buddy
DATABASE_URL=sqlite:///./test.db
DEV_MAIL_API_KEY=your-brevo-api-key
DEV_MAIL_URL=https://api.brevo.com/v3/smtp/email
DEV_MAIL_FROM_NAME=Task Buddy
DEV_MAIL_FROM_EMAIL=your-verified-sender@yourdomain.com
DEV_MAIL_SMTP_HOST=smtp-relay.brevo.com
DEV_MAIL_SMTP_PORT=587
DEV_MAIL_SMTP_USERNAME=your-brevo-smtp-login
DEV_MAIL_SMTP_PASSWORD=your-brevo-smtp-key
DEV_MAIL_SMTP_USE_TLS=True




TEST_MAIL_SMTP_HOST=smtp-relay.brevo.com
TEST_MAIL_SMTP_PORT=587
TEST_MAIL_SMTP_USERNAME=your-brevo-smtp-login
TEST_MAIL_SMTP_PASSWORD=your-brevo-smtp-key
TEST_MAIL_SMTP_USE_TLS=True

TEST_B2_KEY_ID=your-b2-key-id
TEST_B2_APPLICATION_KEY=your-b2-application-key
TEST_B2_BUCKET_NAME=your-b2-bucket-name

# Security Settings
SECRET_KEY=your-secret-key-here-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
CONFIRM_TOKEN_EXPIRE_MINUTES=1440
# SameSite policy for auth cookies. Use "lax" for dev, "none" for production with cross-origin.
COOKIE_SAMESITE=lax

# Redis Settings
REDIS_URL=redis://localhost:6379/0

# CORS Settings
ALLOWED_ORIGINS=["http://localhost:3000", "http://localhost:5173"]

# VAPID Keys for Push Notifications
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_ADMIN_EMAIL=admin@taskbuddy.com

